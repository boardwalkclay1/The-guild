<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Accessing Options – Gateway</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="guild-style.css" />

  <style>
    body {
      margin: 0;
      background: #000;
      color: #D4AF37;
      font-family: system-ui, sans-serif;
      overflow-x: hidden;
    }

    /* Background */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: url("guild-background-gold.png") center/cover no-repeat;
      opacity: 0.18;
      z-index: -3;
      filter: grayscale(40%);
    }

    /* Matrix Canvas */
    #matrixCanvas {
      position: fixed;
      inset: 0;
      z-index: -2;
      opacity: 0.55;
      pointer-events: none;
    }

    /* Hero Section */
    .hero {
      text-align: center;
      padding: 80px 20px 40px;
      position: relative;
      z-index: 2;
    }

    .rune {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      border: 2px solid #D4AF37;
      margin: 0 auto 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Uncial Antiqua', serif;
      font-size: 1.8rem;
      letter-spacing: 0.12em;
      box-shadow: 0 0 25px rgba(212,175,55,0.6);
      position: relative;
    }

    .rune::after {
      content: "";
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      border: 1px solid rgba(212,175,55,0.4);
      animation: pulseRune 3s ease-in-out infinite;
    }

    @keyframes pulseRune {
      0% { transform: scale(1); opacity: 0.7; }
      100% { transform: scale(1.2); opacity: 0; }
    }

    .hero-title {
      font-family: 'Uncial Antiqua', serif;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 1.4rem;
      margin-bottom: 10px;
    }

    .hero-sub {
      font-size: 1rem;
      opacity: 0.9;
      max-width: 500px;
      margin: 0 auto;
    }

    .journey {
      margin-top: 16px;
      font-size: 1.1rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #FFD700;
    }

    /* Dropdown Panel */
    .panel {
      max-width: 800px;
      margin: 40px auto 0;
      background: rgba(0,0,0,0.85);
      border-radius: 16px;
      border: 2px solid #8B6B2C;
      padding: 16px;
      position: relative;
      z-index: 2;
    }

    .panel-header {
      display: flex;
      justify-content: space-between;
      cursor: pointer;
      padding: 6px 4px;
    }

    .panel-title {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.95rem;
    }

    .chevron {
      transition: transform 0.2s ease;
      font-size: 1.2rem;
    }

    .chevron.open {
      transform: rotate(180deg);
    }

    .panel-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
      font-size: 0.9rem;
      margin-top: 6px;
    }

    .panel-body-inner {
      padding-top: 8px;
      border-top: 1px solid rgba(212,175,55,0.25);
    }

    .panel-item {
      margin-bottom: 6px;
    }

    .panel-item strong {
      color: #FFD700;
    }

    .term {
      color: #FFD700;
      cursor: pointer;
      border-bottom: 1px dotted rgba(255,215,0,0.6);
    }

    .term:hover {
      color: #fff;
    }

    /* Explanation Section */
    .explain {
      max-width: 800px;
      margin: 30px auto 0;
      background: rgba(0,0,0,0.9);
      border-radius: 16px;
      border: 1px solid #444;
      padding: 20px;
      line-height: 1.7;
      font-size: 0.95rem;
      z-index: 2;
      position: relative;
    }

    .explain h2 {
      margin-top: 0;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 1rem;
      color: #D4AF37;
    }

    /* Buttons */
    .path-row {
      max-width: 800px;
      margin: 30px auto;
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      justify-content: center;
    }

    .path-btn {
      flex: 1 1 260px;
      max-width: 360px;
      padding: 18px;
      border-radius: 16px;
      border: 2px solid #D4AF37;
      background: radial-gradient(circle at 20% 0%, rgba(212,175,55,0.25), #050505);
      color: #D4AF37;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-weight: 700;
      text-align: center;
      transition: 0.2s ease;
    }

    .path-btn:hover {
      transform: translateY(-2px);
      color: #fff;
      box-shadow: 0 0 25px rgba(255,215,0,0.5);
    }

    .path-btn span {
      display: block;
      font-size: 0.75rem;
      opacity: 0.9;
      margin-top: 6px;
      text-transform: none;
    }

    /* Glossary Modal */
    #glossaryModal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 50;
    }

    .glossary-box {
      max-width: 420px;
      width: 90%;
      background: rgba(5,5,5,0.96);
      border-radius: 16px;
      border: 2px solid #D4AF37;
      padding: 20px;
    }

    .glossary-title {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      margin-bottom: 8px;
    }

    .glossary-body {
      margin-bottom: 12px;
      line-height: 1.6;
    }

    .glossary-actions {
      display: flex;
      gap: 10px;
    }

    .glossary-btn {
      flex: 1;
      padding: 8px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 600;
      font-size: 0.8rem;
    }

    .glossary-btn.primary {
      background: #D4AF37;
      color: #000;
    }

    .glossary-btn.secondary {
      background: #222;
      color: #D4AF37;
      border: 1px solid #555;
    }
  </style>
</head>

<body>

  <canvas id="matrixCanvas"></canvas>

  <div class="hero">
    <div class="rune">Ω</div>
    <div class="hero-title">Accessing Options</div>
    <div class="journey">LET YOUR JOURNEY BEGIN</div>
    <div class="hero-sub">
      This is where the myth meets the mechanics.  
      Learn how to fund, connect, and unlock options in the real world.
    </div>
  </div>

  <!-- Dropdown -->
  <div class="panel" id="panel">
    <div class="panel-header" id="panelHeader">
      <div class="panel-title">What This Path Will Teach You</div>
      <div class="chevron" id="chevron">⌄</div>
    </div>

    <div class="panel-body" id="panelBody">
      <div class="panel-body-inner">
        <div class="panel-item">• How to set up a <strong>bank account</strong> and connect it to a broker.</div>
        <div class="panel-item">• How to open a <strong>broker account</strong> and request <span class="term" data-term="options-approval">options approval</span>.</div>
        <div class="panel-item">• The difference between a <span class="term" data-term="cash-account">cash account</span> and a <span class="term" data-term="margin-account">margin account</span>.</div>
        <div class="panel-item">• How <span class="term" data-term="instant-deposit">instant deposits</span> work vs <span class="term" data-term="ach-transfer">ACH transfers</span>.</div>
        <div class="panel-item">• How to activate <strong>options trading</strong> inside each broker app.</div>
      </div>
    </div>
  </div>

  <!-- Explanation -->
  <div class="explain">
    <h2>The Bridge Between Your Money and the Market</h2>
    <p>Your bank holds your cash. Your broker gives you <strong>buying power</strong>. Connecting them unlocks your ability to trade.</p>
    <p>Some brokers offer <span class="term" data-term="instant-deposit">instant deposits</span>. Others rely on slower <span class="term" data-term="ach-transfer">ACH transfers</span>.</p>
    <p>Many will ask if you want a <span class="term" data-term="margin-account">margin account</span>, which allows borrowing but adds risk.</p>
    <p>This path walks you through realistic modules that mirror the actual apps step by step.</p>
  </div>

  <!-- Buttons -->
  <div class="path-row">
    <a class="path-btn" href="banks.html">
      BANKS
      <span>Learn how to set up and connect your bank account.</span>
    </a>

    <a class="path-btn" href="brokers.html">
      BROKERS
      <span>Learn how to open a broker account and activate options.</span>
    </a>
  </div>

  <!-- Glossary Modal -->
  <div id="glossaryModal">
    <div class="glossary-box">
      <div class="glossary-title" id="glossaryTitle"></div>
      <div class="glossary-body" id="glossaryBody"></div>
      <div class="glossary-actions">
        <button class="glossary-btn secondary" id="closeGlossary">Close</button>
        <button class="glossary-btn primary" onclick="window.location.href='glossary.html'">Full Glossary</button>
      </div>
    </div>
  </div>

  <script>
    /* MATRIX */
    const canvas = document.getElementById("matrixCanvas");
    const ctx = canvas.getContext("2d");

    let w, h, cols, drops;
    const chars = "0123456789ΩΛΞ∑$#/*";

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
      const fontSize = 16;
      cols = Math.floor(w / fontSize);
      drops = Array(cols).fill(0);
    }
    resize();
    window.addEventListener("resize", resize);

    function draw() {
      ctx.fillStyle = "rgba(0,0,0,0.15)";
      ctx.fillRect(0, 0, w, h);

      ctx.fillStyle = "#D4AF37";
      ctx.font = "16px monospace";

      for (let i = 0; i < cols; i++) {
        const char = chars[Math.floor(Math.random() * chars.length)];
        const x = i * 16;
        const y = drops[i] * 16;

        ctx.fillText(char, x, y);

        if (y > h && Math.random() > 0.95) drops[i] = 0;
        drops[i]++;
      }

      requestAnimationFrame(draw);
    }
    draw();

    /* DROPDOWN */
    const panelHeader = document.getElementById("panelHeader");
    const panelBody = document.getElementById("panelBody");
    const chevron = document.getElementById("chevron");

    let open = false;

    function togglePanel() {
      open = !open;
      panelBody.style.maxHeight = open ? panelBody.scrollHeight + "px" : "0px";
      chevron.classList.toggle("open", open);
    }

    panelHeader.addEventListener("click", togglePanel);

    setTimeout(() => togglePanel(), 1200);

    /* GLOSSARY */
    const glossaryModal = document.getElementById("glossaryModal");
    const glossaryTitle = document.getElementById("glossaryTitle");
    const glossaryBody = document.getElementById("glossaryBody");
    const closeGlossary = document.getElementById("closeGlossary");

    const glossary = {
      "options-approval": "A review process where the broker decides what level of options trading you are allowed to access.",
      "cash-account": "A brokerage account where you can only trade using the cash you have deposited.",
      "margin-account": "A brokerage account that allows you to borrow money from the broker to trade.",
      "instant-deposit": "A feature where the broker gives you immediate buying power before your deposit fully settles.",
      "ach-transfer": "A bank-to-bank transfer through the Automated Clearing House network, usually taking 1–4 days."
    };

    document.querySelectorAll(".term").forEach(t => {
      t.addEventListener("click", () => {
        const key = t.dataset.term;
        glossaryTitle.textContent = t.textContent;
        glossaryBody.textContent = glossary[key];
        glossaryModal.style.display = "flex";
      });
    });

    closeGlossary.addEventListener("click", () => {
      glossaryModal.style.display = "none";
    });

    glossaryModal.addEventListener("click", e => {
      if (e.target === glossaryModal) glossaryModal.style.display = "none";
    });
  </script>

</body>
</html>
